{
  "name": "srch",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adityavkk/srch.git"
  },
  "bugs": {
    "url": "https://github.com/adityavkk/srch/issues"
  },
  "homepage": "https://github.com/adityavkk/srch#readme",
  "type": "module",
  "main": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk.d.ts",
      "default": "./dist/sdk.js"
    }
  },
  "bin": {
    "search": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test test/*.test.ts test/sdk/*.test.ts",
    "install:optional": "tsx src/cli.ts install",
    "install:all": "tsx src/cli.ts install all"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@steipete/bird": "^0.8.0",
    "@tobilu/qmd": "^2.1.0",
    "linkedom": "^0.18.12",
    "tsx": "^4.20.5",
    "turndown": "^7.2.1",
    "unpdf": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "simple-git": ">=3.36.0"
  }
}
